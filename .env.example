# Gocrewwai Environment Configuration Example
# Copy this file to .env and fill in your keys.

# --- LLM Providers ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# --- E2B Cloud Sandbox ---
# Get your key at https://e2b.dev
CREW_GO_E2B_API_KEY=e2b_...

# --- Framework Defaults ---
CREW_GO_DEFAULT_MODEL=gpt-4o
CREW_GO_DEFAULT_PROVIDER=openai
CREW_GO_LOG_LEVEL=info
CREW_GO_VERBOSE=false

# --- Memory Settings ---
CREW_GO_MEMORY_BACKEND=sqlite
CREW_GO_MEMORY_DB_PATH=./crew_memory.db
